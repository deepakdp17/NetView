# NetView Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# Database
DB_PASSWORD=netview_dev

# JWT signing secret (minimum 32 characters for HS256)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-prod

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:4200
